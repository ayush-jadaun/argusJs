# Database (use one or the other)
DATABASE_URL=postgres://argus:argus@localhost:5432/argus
MONGO_URL=mongodb://localhost:27017/argus

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ALGORITHM=rs256          # rs256 (default) | es256 | hs256
JWT_SECRET=                  # Required for hs256 (min 32 chars)
JWT_PRIVATE_KEY=
JWT_KEY_ID=dev-key-001
JWT_ISSUER=auth.localhost
JWT_AUDIENCE=api.localhost

# MFA
MFA_ENCRYPTION_KEY=
MFA_APP_NAME=ArgusJS

# Email
SENDGRID_API_KEY=
EMAIL_FROM=noreply@localhost

# Server
PORT=3100
HOST=0.0.0.0
LOG_LEVEL=debug

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3100

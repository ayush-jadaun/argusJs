{
  "name": "@argusjs/server",
  "version": "0.1.4",
  "license": "Apache-2.0",
  "repository": {
  "publishConfig": { "access": "public" },
    "type": "git",
    "url": "https://github.com/ayush-jadaun/argusJs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@argusjs/cache-memory": "workspace:*",
    "@argusjs/cache-redis": "workspace:*",
    "@argusjs/core": "workspace:*",
    "@argusjs/db-postgres": "workspace:*",
    "@argusjs/email-memory": "workspace:*",
    "@argusjs/hash-argon2": "workspace:*",
    "@argusjs/ratelimit-memory": "workspace:*",
    "@argusjs/ratelimit-redis": "workspace:*",
    "@argusjs/token-jwt-es256": "workspace:*",
    "@argusjs/token-jwt-hs256": "workspace:*",
    "@argusjs/token-jwt-rs256": "workspace:*",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@argusjs/db-memory": "workspace:*",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
